#!/bin/bash
set -e

ORIGINAL_BRANCH=$(git branch --show-current)

if [[ -n $(git status --porcelain) ]]; then
    echo "✗ Working tree is dirty; commit or stash first"
    exit 1
fi

if git show-ref --verify --quiet refs/heads/main; then
    BASE="main"
elif git show-ref --verify --quiet refs/heads/master; then
    BASE="master"
else
    echo "✗ No main or master branch found; aborting"
    exit 1
fi

git checkout -q "$BASE"
git pull -q origin "$BASE"

# Delete jabid/ branches whose upstream is gone (squash-merged PRs)
git for-each-ref --format '%(refname:short) %(upstream:track)' refs/heads/jabid/ \
    | awk '$2 == "[gone]" {print $1}' \
    | while read -r branch; do
        git branch -D "$branch"
        echo "✗ $branch (upstream gone)"
    done

if git show-ref --verify --quiet refs/heads/local; then
    OLD_LOCAL=$(git rev-parse local)
    git checkout -q local
    if git rebase -q "$BASE" >/dev/null 2>&1; then
        echo "✓ local"
    else
        git rebase --abort >/dev/null 2>&1
        git checkout -q "$ORIGINAL_BRANCH" 2>/dev/null || git checkout -q "$BASE"
        echo "✗ Failed to rebase local; aborting"
        exit 1
    fi
    REBASE=(-q --onto local "$OLD_LOCAL")
else
    REBASE=(-q "$BASE")
fi

while IFS= read -r branch; do
    if git checkout -q "$branch" 2>/dev/null \
        && git rebase "${REBASE[@]}" >/dev/null 2>&1; then
        echo "✓ $branch"
    else
        git rebase --abort >/dev/null 2>&1
        echo "✗ $branch"
    fi
done < <(git branch --no-merged "$BASE" | grep 'jabid/' | sed 's/^[* ]*//')

git checkout -q "$ORIGINAL_BRANCH" 2>/dev/null || git checkout -q "$BASE"

# Delete jabid/ branches with no diff against base (effectively merged)
while IFS= read -r branch; do
    if [[ "$branch" != "$ORIGINAL_BRANCH" ]] \
        && [[ -z "$(git diff "$BASE" "$branch")" ]]; then
        git branch --delete --force "$branch"
        echo "✗ $branch (empty, deleted)"
    fi
done < <(git for-each-ref --format='%(refname:short)' refs/heads/jabid/)
