// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": { "notify_when_agent_waiting": "never" },
  "agent_servers": {
    "claude-acp": {
      "default_config_options": { "model": "opus[1m]", "mode": "auto" },
      "type": "registry",
    },
    "opencode": {
      "default_config_options": { "effort": "medium", "model": "grove-openai/gpt-5.3-codex" },
      "favorite_config_option_values": { "model": ["grove-openai/gpt-5.3-codex"] },
      "type": "registry",
    },
    "pi-acp": { "type": "registry" },
  },
  "base_keymap": "VSCode",
  "cli_default_open_behavior": "new_window",
  "collaboration_panel": { "button": false },
  "colorize_brackets": true,
  "file_types": {
    "Git Attributes": ["**/{git,.git,.git/info}/attributes"],
    "Git Config": ["*.gitconfig", "**/{git,.git,.git/modules,.git/modules/*}/config"],
    "Git Ignore": ["**/{git,.git}/ignore", "**/.git/info/exclude"],
    "html": ["*.tera"],
  },
  "git_panel": { "tree_view": true },
  "indent_guides": { "coloring": "indent_aware" },
  "languages": {
    "CSS": {
      "language_servers": ["tailwindcss-intellisense-css", "!vscode-css-language-server", "..."],
    },
    "Git Commit": { "wrap_guides": [50, 72] },
    "Python": {
      "code_actions_on_format": {
        "source.fixAll.ruff": true,
        "source.organizeImports": true,
      },
      "format_on_save": "on",
      "formatter": { "language_server": { "name": "ruff" } },
      "language_servers": ["ty", "ruff", "!basedpyright", "!pyright"],
    },
    "TSX": { "wrap_guides": [80, 100] },
  },
  "lsp": {
    "ruff": {
      "initialization_options": {
        "settings": {
          "format": { "enable": true },
          "lint": { "enable": true },
          "organizeImports": true,
        },
      },
    },
  },
  "preferred_line_length": 100,
  "project_panel": {
    "diagnostic_badges": true,
    "file_icons": false,
    "git_status_indicator": true,
    "hide_gitignore": true,
    "hide_hidden": false,
    "hide_root": true,
  },
  "search": { "button": false },
  "show_whitespaces": "selection",
  "soft_wrap": "bounded",
  "tab_bar": { "show_nav_history_buttons": false },
  "tabs": { "file_icons": true, "git_status": true },
  "terminal": {
    "env": { "GIT_EDITOR": "zed --wait" },
  },
  "theme": {
    "dark": "One Dark",
    "light": "Flexoki Light",
    "mode": "system",
  },
  "ui_font_size": 16,
  "use_smartcase_search": true,
  "use_system_path_prompts": false,
  "use_system_prompts": true,
  "use_system_window_tabs": true,
  "vim": { "gdefault": true, "use_smartcase_find": true },
  "vim_mode": true, // See https://zed.dev/docs/vim for keybindings
  "which_key": { "delay_ms": 500, "enabled": true },
}
